---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Wulfre's Website">
    <main class="w-35ch flex flex-col gap-5 b-1 b-paper p-5 text-justify">
        <h1 class="text-8 text-center">{"Hey, it's me, Wulfre."}</h1>
        <p>
            {
                "Welcome to my website. This is my website. There is no particularly meaningful content on my website. Thank you for visiting my website."
            }
        </p>
        <p>{"Have some links related to me:"}</p>
        <div class="flex justify-around">
            <a
                class="bg-highlighter-blue-bg c-highlighter-blue hover:c-highlighter-blue-muted transition underline py-1 px-2"
                href="https://github.com/wulfre">GitHub</a
            >
            <a
                class="bg-highlighter-blue-bg c-highlighter-blue hover:c-highlighter-blue-muted transition underline py-1 px-2"
                href="https://twitter.com/_wulfre">Twitter</a
            >
        </div>
    </main>
</Layout>
